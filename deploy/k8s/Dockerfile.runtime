FROM ubuntu:24.04

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        libgcc-s1 \
        libstdc++6 \
        tzdata \
    && rm -rf /var/lib/apt/lists/*

ARG RUNTIME_ROOT=deploy/k8s/runtime/linux

WORKDIR /app
COPY ${RUNTIME_ROOT}/ /app/

RUN mkdir -p /app/bin/etc /app/bin/logs \
    && chmod +x /app/bin/gate /app/bin/scene
