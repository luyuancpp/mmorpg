# Production-like profile: closer to cluster behavior for load/regression testing
KAFKA_HEAP_OPTS=-Xms512m -Xmx1g
KAFKA_LOG_RETENTION_MS=300000
KAFKA_LOG_RETENTION_CHECK_INTERVAL_MS=120000
KAFKA_LOG_RETENTION_BYTES=536870912
KAFKA_LOG_SEGMENT_BYTES=33554432
KAFKA_NUM_IO_THREADS=8
KAFKA_NUM_NETWORK_THREADS=3
KAFKA_BACKGROUND_THREADS=10
KAFKA_MEM_LIMIT=1536M
KAFKA_CPU_LIMIT=2.0
KAFKA_TMPFS_SIZE=512m
KAFKA_UI_JAVA_OPTS=-Xms256m -Xmx512m
KAFKA_UI_MEM_LIMIT=768M
KAFKA_UI_CPU_LIMIT=1.0
