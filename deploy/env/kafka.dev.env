# Development profile: minimal resources, fastest feedback
KAFKA_HEAP_OPTS=-Xms128m -Xmx256m
KAFKA_LOG_RETENTION_MS=60000
KAFKA_LOG_RETENTION_CHECK_INTERVAL_MS=120000
KAFKA_LOG_RETENTION_BYTES=134217728
KAFKA_LOG_SEGMENT_BYTES=16777216
KAFKA_NUM_IO_THREADS=1
KAFKA_NUM_NETWORK_THREADS=1
KAFKA_BACKGROUND_THREADS=2
KAFKA_MEM_LIMIT=512M
KAFKA_CPU_LIMIT=0.5
KAFKA_TMPFS_SIZE=256m
KAFKA_UI_JAVA_OPTS=-Xms128m -Xmx256m
KAFKA_UI_MEM_LIMIT=384M
KAFKA_UI_CPU_LIMIT=0.5
