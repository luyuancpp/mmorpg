			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-File",
				"${workspaceFolder}/tools/scripts/verify_grpc_client_build.ps1"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "third_party: grpc build",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-NoProfile",
				"-File",
				"${workspaceFolder}/tools/scripts/dev_tools.ps1",
