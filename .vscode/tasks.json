		{
			"label": "dev: start all (C++ + Go)",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-File",
				"${workspaceFolder}/tools/scripts/dev_tools.ps1",
				"-Command",
				"dev-start"
			],
			"problemMatcher": []
		},
		{
			"label": "dev: stop all (C++ + Go)",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-File",
				"${workspaceFolder}/tools/scripts/dev_tools.ps1",
				"-Command",
				"dev-stop"
			],
