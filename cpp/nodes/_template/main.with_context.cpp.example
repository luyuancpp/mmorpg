namespace {

// Keep runtime-owned state here (timers, codecs, bridges, etc.).
struct YourNodeRuntimeContext {
    // TimerTaskComp timer;
};

struct YourNodeHooks {
    using KafkaCommandType = contracts::kafka::YourNodeCommand;
};

} // namespace

int main(int argc, char* argv[])
{
    return node::entry::RunSimpleNodeMainWithOwnedContext<YourNodeHandler, YourNodeRuntimeContext, YourNodeHooks>(
        "logs/your_node",
        YourNodeService,
        Node::CanConnectNodeTypeList{ /* SceneNodeService, LoginNodeService, ... */ },
        [](Node& node, YourNodeRuntimeContext& context) {
            // Optional: node lifecycle callbacks.
            node.SetAfterStart([&context](Node& n) {
                // Example: context.timer.RunEvery(1.0, [] {});
                // (void)n;
            });
        });
}
