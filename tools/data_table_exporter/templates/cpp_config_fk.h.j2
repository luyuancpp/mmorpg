{# cpp_config_fk.h.j2 -- foreign key cross-table lookup helpers #}
#pragma once
#include <vector>
#include "{{ sheetname | lower }}_table.h"
{% for target in fk_targets %}
#include "{{ target | lower }}_table.h"
{% endfor %}

// ---------------------------------------------------------------------------
// Foreign key helpers for {{ sheetname }}Table
// ---------------------------------------------------------------------------
{% for col in table.foreign_key_columns %}
{% if col.is_repeated %}

/// Resolve {{ sheetname }}.{{ col.name }}[] -> {{ col.foreign_key.target_table }} rows.
inline std::vector<const {{ col.foreign_key.target_table }}Table*> Get{{ sheetname }}{{ to_pascal_case(col.name) }}Rows(const {{ sheetname }}Table& row) {
    std::vector<const {{ col.foreign_key.target_table }}Table*> result;
    for (auto id : row.{{ col.name }}()) {
        auto [ptr, _] = {{ col.foreign_key.target_table }}TableManager::Instance().FindByIdSilent(id);
        if (ptr) result.push_back(ptr);
    }
    return result;
}

/// Resolve {{ sheetname }}.{{ col.name }}[] -> {{ col.foreign_key.target_table }} rows (by {{ sheetname }} id).
inline std::vector<const {{ col.foreign_key.target_table }}Table*> Get{{ sheetname }}{{ to_pascal_case(col.name) }}Rows(uint32_t tableId) {
    auto [row, _] = {{ sheetname }}TableManager::Instance().FindByIdSilent(tableId);
    if (!row) return {};
    return Get{{ sheetname }}{{ to_pascal_case(col.name) }}Rows(*row);
}
{% else %}

/// Resolve {{ sheetname }}.{{ col.name }} -> {{ col.foreign_key.target_table }} row.
inline const {{ col.foreign_key.target_table }}Table* Get{{ sheetname }}{{ to_pascal_case(col.name) }}Row(const {{ sheetname }}Table& row) {
    auto [ptr, _] = {{ col.foreign_key.target_table }}TableManager::Instance().FindByIdSilent(row.{{ col.name }}());
    return ptr;
}

/// Resolve {{ sheetname }}.{{ col.name }} -> {{ col.foreign_key.target_table }} row (by {{ sheetname }} id).
inline const {{ col.foreign_key.target_table }}Table* Get{{ sheetname }}{{ to_pascal_case(col.name) }}Row(uint32_t tableId) {
    auto [row, _] = {{ sheetname }}TableManager::Instance().FindByIdSilent(tableId);
    if (!row) return nullptr;
    return Get{{ sheetname }}{{ to_pascal_case(col.name) }}Row(*row);
}
{% endif %}
{% endfor %}
{% for col in table.group_foreign_key_columns %}

/// Resolve {{ sheetname }}.{{ col.name }}[] -> {{ col.group_foreign_key.target_table }} rows.
inline std::vector<const {{ col.group_foreign_key.target_table }}Table*> Get{{ sheetname }}{{ to_pascal_case(col.name) }}Rows(const {{ sheetname }}Table& row) {
    std::vector<const {{ col.group_foreign_key.target_table }}Table*> result;
    for (auto id : row.{{ col.name }}()) {
        auto [ptr, _] = {{ col.group_foreign_key.target_table }}TableManager::Instance().FindByIdSilent(id);
        if (ptr) result.push_back(ptr);
    }
    return result;
}

/// Resolve {{ sheetname }}.{{ col.name }}[] -> {{ col.group_foreign_key.target_table }} rows (by {{ sheetname }} id).
inline std::vector<const {{ col.group_foreign_key.target_table }}Table*> Get{{ sheetname }}{{ to_pascal_case(col.name) }}Rows(uint32_t tableId) {
    auto [row, _] = {{ sheetname }}TableManager::Instance().FindByIdSilent(tableId);
    if (!row) return {};
    return Get{{ sheetname }}{{ to_pascal_case(col.name) }}Rows(*row);
}
{% endfor %}

// ---------------------------------------------------------------------------
// Reverse FK (HasMany): find source rows by FK column value
// ---------------------------------------------------------------------------
{% for col in table.foreign_key_columns if not col.is_repeated %}

/// Reverse FK: find all {{ sheetname }} rows whose {{ col.name }} == key.
inline const std::vector<const {{ sheetname }}Table*>& Find{{ sheetname }}RowsBy{{ to_pascal_case(col.name) }}({{ to_cpp_param_type(col.data_type) }} key) {
    return {{ sheetname }}TableManager::Instance().GetBy{{ to_pascal_case(col.name) }}(key);
}
{% endfor %}
