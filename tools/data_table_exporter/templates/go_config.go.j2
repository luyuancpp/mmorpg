package table

import (
    "fmt"
    "math/rand/v2"
    "os"
    "path/filepath"

    "google.golang.org/protobuf/encoding/protojson"
    "google.golang.org/protobuf/proto"
    pb "{{ proto_import_path }}"
)

{% for ck in table.composite_keys %}
type {{ sheetname }}{{ composite_go_struct_name(ck.group) }} struct {
{%- for col in ck.columns %}
    {{ to_go_proto_field(col.name) }} {{ to_go_type(col.data_type) }}
{%- endfor %}
}
