// {{ sheetname | lower }}Snapshot holds all parsed data and indices.
// Load() builds a new snapshot and swaps it in, replacing the old one.
type {{ sheetname | lower }}Snapshot struct {
    data   []*pb.{{ sheetname }}Table
    kvData map[{{ to_go_type(table.id_column.data_type) }}]*pb.{{ sheetname }}Table
{%- for col in table.table_keys if not col.is_multi_key %}
    kv{{ col.name | title }}Data map[{{ to_go_type(col.data_type) }}]*pb.{{ sheetname }}Table
{%- endfor %}
{%- for col in table.table_keys if col.is_multi_key %}
    kv{{ col.name | title }}Data map[{{ to_go_type(col.data_type) }}][]*pb.{{ sheetname }}Table
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
    idx{{ arr.name | title }} map[{{ to_go_type(arr.data_type) }}][]*pb.{{ sheetname }}Table
{%- endfor %}
{%- for col in table.index_columns %}
    idx{{ to_go_proto_field(col.name) }} map[{{ to_go_type(col.data_type) }}][]*pb.{{ sheetname }}Table
{%- endfor %}
{%- for ck in table.composite_keys %}
    compositeKv{{ ck.group | title }} map[{{ sheetname }}{{ composite_go_struct_name(ck.group) }}]*pb.{{ sheetname }}Table
{%- endfor %}
}

type {{ sheetname }}TableManager struct {
    snap *{{ sheetname | lower }}Snapshot
}

var {{ sheetname }}TableManagerInstance = New{{ sheetname }}TableManager()

func New{{ sheetname }}TableManager() *{{ sheetname }}TableManager {
    return &{{ sheetname }}TableManager{
        snap: &{{ sheetname | lower }}Snapshot{
            kvData: make(map[{{ to_go_type(table.id_column.data_type) }}]*pb.{{ sheetname }}Table),
{%- for col in table.table_keys if not col.is_multi_key %}
            kv{{ col.name | title }}Data: make(map[{{ to_go_type(col.data_type) }}]*pb.{{ sheetname }}Table),
{%- endfor %}
{%- for col in table.table_keys if col.is_multi_key %}
            kv{{ col.name | title }}Data: make(map[{{ to_go_type(col.data_type) }}][]*pb.{{ sheetname }}Table),
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
            idx{{ arr.name | title }}: make(map[{{ to_go_type(arr.data_type) }}][]*pb.{{ sheetname }}Table),
{%- endfor %}{%- for col in table.index_columns %}
            idx{{ to_go_proto_field(col.name) }}: make(map[{{ to_go_type(col.data_type) }}][]*pb.{{ sheetname }}Table),
{%- endfor %}{%- for ck in table.composite_keys %}
            compositeKv{{ ck.group | title }}: make(map[{{ sheetname }}{{ composite_go_struct_name(ck.group) }}]*pb.{{ sheetname }}Table),
{%- endfor %}
        },
    }
}

func (m *{{ sheetname }}TableManager) Load(configDir string, useBinary bool) error {
    var container pb.{{ sheetname }}TableData

    if useBinary {
        path := filepath.Join(configDir, "{{ sheetname | lower }}.pb")
        raw, err := os.ReadFile(path)
        if err != nil {
            return fmt.Errorf("failed to read file: %w", err)
        }
        if err := proto.Unmarshal(raw, &container); err != nil {
            return fmt.Errorf("failed to parse binary: %w", err)
        }
    } else {
        path := filepath.Join(configDir, "{{ sheetname | lower }}.json")
        raw, err := os.ReadFile(path)
        if err != nil {
            return fmt.Errorf("failed to read file: %w", err)
        }
        if err := protojson.Unmarshal(raw, &container); err != nil {
            return fmt.Errorf("failed to parse json: %w", err)
        }
    }

    snap := &{{ sheetname | lower }}Snapshot{
        kvData: make(map[{{ to_go_type(table.id_column.data_type) }}]*pb.{{ sheetname }}Table, len(container.Data)),
{%- for col in table.table_keys if not col.is_multi_key %}
        kv{{ col.name | title }}Data: make(map[{{ to_go_type(col.data_type) }}]*pb.{{ sheetname }}Table, len(container.Data)),
{%- endfor %}
{%- for col in table.table_keys if col.is_multi_key %}
        kv{{ col.name | title }}Data: make(map[{{ to_go_type(col.data_type) }}][]*pb.{{ sheetname }}Table),
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
        idx{{ arr.name | title }}: make(map[{{ to_go_type(arr.data_type) }}][]*pb.{{ sheetname }}Table),
{%- endfor %}
{%- for col in table.index_columns %}
        idx{{ to_go_proto_field(col.name) }}: make(map[{{ to_go_type(col.data_type) }}][]*pb.{{ sheetname }}Table),
{%- endfor %}
{%- for ck in table.composite_keys %}
        compositeKv{{ ck.group | title }}: make(map[{{ sheetname }}{{ composite_go_struct_name(ck.group) }}]*pb.{{ sheetname }}Table, len(container.Data)),
{%- endfor %}
    }

    for _, row := range container.Data {
        snap.kvData[row.Id] = row
{%- for col in table.table_keys if not col.is_multi_key %}
        snap.kv{{ col.name | title }}Data[row.{{ to_go_proto_field(col.name) }}] = row
{%- endfor %}
{%- for col in table.table_keys if col.is_multi_key %}
        snap.kv{{ col.name | title }}Data[row.{{ to_go_proto_field(col.name) }}] = append(snap.kv{{ col.name | title }}Data[row.{{ to_go_proto_field(col.name) }}], row)
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
        for _, elem := range row.{{ to_go_proto_field(arr.name) }} {
            snap.idx{{ arr.name | title }}[elem] = append(snap.idx{{ arr.name | title }}[elem], row)
        }
{%- endfor %}
{%- for col in table.index_columns %}
        snap.idx{{ to_go_proto_field(col.name) }}[row.{{ to_go_proto_field(col.name) }}] = append(snap.idx{{ to_go_proto_field(col.name) }}[row.{{ to_go_proto_field(col.name) }}], row)
{%- endfor %}
{%- for ck in table.composite_keys %}
        snap.compositeKv{{ ck.group | title }}[{{ sheetname }}{{ composite_go_struct_name(ck.group) }}{ {%- for col in ck.columns %}{{ to_go_proto_field(col.name) }}: row.{{ to_go_proto_field(col.name) }}, {% endfor -%} }] = row
{%- endfor %}
    }

    snap.data = container.Data
    m.snap = snap
    return nil
}

func (m *{{ sheetname }}TableManager) FindAll() []*pb.{{ sheetname }}Table {
    return m.snap.data
}

func (m *{{ sheetname }}TableManager) FindById(id {{ to_go_type(table.id_column.data_type) }}) (*pb.{{ sheetname }}Table, bool) {
    row, ok := m.snap.kvData[id]
    return row, ok
}

{% for col in table.table_keys if not col.is_multi_key -%}
func (m *{{ sheetname }}TableManager) FindBy{{ col.name | title }}(key {{ to_go_type(col.data_type) }}) (*pb.{{ sheetname }}Table, bool) {
    row, ok := m.snap.kv{{ col.name | title }}Data[key]
    return row, ok
}

{% endfor %}
{%- for col in table.table_keys if col.is_multi_key %}
func (m *{{ sheetname }}TableManager) FindBy{{ col.name | title }}(key {{ to_go_type(col.data_type) }}) []*pb.{{ sheetname }}Table {
    return m.snap.kv{{ col.name | title }}Data[key]
}

{% endfor %}
{%- for arr in table.repeated_comp_arrays %}
func (m *{{ sheetname }}TableManager) FindBy{{ arr.name | title }}Index(key {{ to_go_type(arr.data_type) }}) []*pb.{{ sheetname }}Table {
    return m.snap.idx{{ arr.name | title }}[key]
}

{% endfor %}
{%- for col in table.index_columns %}
func (m *{{ sheetname }}TableManager) GetBy{{ to_go_proto_field(col.name) }}(key {{ to_go_type(col.data_type) }}) []*pb.{{ sheetname }}Table {
    return m.snap.idx{{ to_go_proto_field(col.name) }}[key]
}

{% endfor %}

// ---- Exists ----

func (m *{{ sheetname }}TableManager) Exists(id {{ to_go_type(table.id_column.data_type) }}) bool {
    _, ok := m.snap.kvData[id]
    return ok
}

{% for col in table.table_keys if not col.is_multi_key -%}
func (m *{{ sheetname }}TableManager) ExistsBy{{ col.name | title }}(key {{ to_go_type(col.data_type) }}) bool {
