// ---- Count ----

func (m *{{ sheetname }}TableManager) Count() int {
    return len(m.snap.data)
}

{% for col in table.table_keys if col.is_multi_key -%}
func (m *{{ sheetname }}TableManager) CountBy{{ col.name | title }}(key {{ to_go_type(col.data_type) }}) int {
    return len(m.snap.kv{{ col.name | title }}Data[key])
}

{% endfor %}
{%- for arr in table.repeated_comp_arrays %}
func (m *{{ sheetname }}TableManager) CountBy{{ arr.name | title }}Index(key {{ to_go_type(arr.data_type) }}) int {
    return len(m.snap.idx{{ arr.name | title }}[key])
}

{% endfor %}
{%- for col in table.index_columns %}
func (m *{{ sheetname }}TableManager) CountBy{{ to_go_proto_field(col.name) }}Index(key {{ to_go_type(col.data_type) }}) int {
    return len(m.snap.idx{{ to_go_proto_field(col.name) }}[key])
}

{% endfor %}

// ---- FindByIds (IN) ----

func (m *{{ sheetname }}TableManager) FindByIds(ids []{{ to_go_type(table.id_column.data_type) }}) []*pb.{{ sheetname }}Table {
    result := make([]*pb.{{ sheetname }}Table, 0, len(ids))
    for _, id := range ids {
        if row, ok := m.snap.kvData[id]; ok {
            result = append(result, row)
        }
    }
    return result
}

// ---- RandOne ----

func (m *{{ sheetname }}TableManager) RandOne() (*pb.{{ sheetname }}Table, bool) {
    if len(m.snap.data) == 0 {
        return nil, false
    }
    return m.snap.data[rand.IntN(len(m.snap.data))], true
}

{% for col in table.table_keys if col.is_multi_key -%}
func (m *{{ sheetname }}TableManager) RandOneBy{{ col.name | title }}(key {{ to_go_type(col.data_type) }}) (*pb.{{ sheetname }}Table, bool) {
    rows := m.snap.kv{{ col.name | title }}Data[key]
    if len(rows) == 0 {
        return nil, false
    }
    return rows[rand.IntN(len(rows))], true
}

{% endfor %}

// ---- Where / First ----

func (m *{{ sheetname }}TableManager) Where(pred func(*pb.{{ sheetname }}Table) bool) []*pb.{{ sheetname }}Table {
    var result []*pb.{{ sheetname }}Table
    for _, row := range m.snap.data {
        if pred(row) {
            result = append(result, row)
        }
    }
    return result
}

func (m *{{ sheetname }}TableManager) First(pred func(*pb.{{ sheetname }}Table) bool) (*pb.{{ sheetname }}Table, bool) {
    for _, row := range m.snap.data {
        if pred(row) {
            return row, true
        }
    }
    return nil, false
}

