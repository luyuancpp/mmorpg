{# go_config.go.j2 — per-table config manager struct #}
package table

import (
    "fmt"
    "os"
    "path/filepath"

    "google.golang.org/protobuf/encoding/protojson"
    "google.golang.org/protobuf/proto"
    pb "{{ proto_import_path }}"
)

type {{ sheetname }}TableManager struct {
    data   []*pb.{{ sheetname }}Table
    kvData map[{{ to_go_type(table.id_column.data_type) }}]*pb.{{ sheetname }}Table
{%- for col in table.table_keys %}
    kv{{ col.name | title }}Data map[{{ to_go_type(col.data_type) }}]*pb.{{ sheetname }}Table
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
    idx{{ arr.name | title }} map[{{ to_go_type(arr.data_type) }}][]*pb.{{ sheetname }}Table
{%- endfor %}
}

var {{ sheetname }}TableManagerInstance = New{{ sheetname }}TableManager()

func New{{ sheetname }}TableManager() *{{ sheetname }}TableManager {
    return &{{ sheetname }}TableManager{
        kvData: make(map[{{ to_go_type(table.id_column.data_type) }}]*pb.{{ sheetname }}Table),
{%- for col in table.table_keys %}
        kv{{ col.name | title }}Data: make(map[{{ to_go_type(col.data_type) }}]*pb.{{ sheetname }}Table),
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
        idx{{ arr.name | title }}: make(map[{{ to_go_type(arr.data_type) }}][]*pb.{{ sheetname }}Table),
{%- endfor %}
    }
}

func (m *{{ sheetname }}TableManager) Load(configDir string, useBinary bool) error {
    var container pb.{{ sheetname }}TableData

    if useBinary {
        path := filepath.Join(configDir, "{{ sheetname | lower }}.pb")
        raw, err := os.ReadFile(path)
        if err != nil {
            return fmt.Errorf("failed to read file: %w", err)
        }
        if err := proto.Unmarshal(raw, &container); err != nil {
            return fmt.Errorf("failed to parse binary: %w", err)
        }
    } else {
        path := filepath.Join(configDir, "{{ sheetname | lower }}.json")
        raw, err := os.ReadFile(path)
        if err != nil {
            return fmt.Errorf("failed to read file: %w", err)
        }
        if err := protojson.Unmarshal(raw, &container); err != nil {
            return fmt.Errorf("failed to parse json: %w", err)
        }
    }

    for _, row := range container.Data {
        m.kvData[row.Id] = row
{%- for col in table.table_keys %}
        m.kv{{ col.name | title }}Data[row.{{ to_go_proto_field(col.name) }}] = row
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
        for _, elem := range row.{{ to_go_proto_field(arr.name) }} {
            m.idx{{ arr.name | title }}[elem] = append(m.idx{{ arr.name | title }}[elem], row)
        }
{%- endfor %}
    }

    m.data = container.Data
    return nil
}

func (m *{{ sheetname }}TableManager) GetAll() []*pb.{{ sheetname }}Table {
    return m.data
}

func (m *{{ sheetname }}TableManager) GetById(id {{ to_go_type(table.id_column.data_type) }}) (*pb.{{ sheetname }}Table, bool) {
    row, ok := m.kvData[id]
    return row, ok
}

{% for col in table.table_keys -%}
func (m *{{ sheetname }}TableManager) GetBy{{ col.name | title }}(key {{ to_go_type(col.data_type) }}) (*pb.{{ sheetname }}Table, bool) {
    row, ok := m.kv{{ col.name | title }}Data[key]
    return row, ok
}

{% endfor %}
{%- for arr in table.repeated_comp_arrays %}
func (m *{{ sheetname }}TableManager) GetBy{{ arr.name | title }}Index(key {{ to_go_type(arr.data_type) }}) []*pb.{{ sheetname }}Table {
    return m.idx{{ arr.name | title }}[key]
}

{% endfor %}
