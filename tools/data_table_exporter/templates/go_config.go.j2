// ---- Batch Lookup (IN) ----

func (m *{{ sheetname }}TableManager) GetByIds(ids []{{ to_go_type(table.id_column.data_type) }}) []*pb.{{ sheetname }}Table {
    result := make([]*pb.{{ sheetname }}Table, 0, len(ids))
    for _, id := range ids {
        if row, ok := m.kvData[id]; ok {
            result = append(result, row)
        }
    }
    return result
}

// ---- Random ----

func (m *{{ sheetname }}TableManager) GetRandom() (*pb.{{ sheetname }}Table, bool) {
    if len(m.data) == 0 {
        return nil, false
    }
    return m.data[rand.IntN(len(m.data))], true
}

{% for col in table.table_keys if col.is_multi_key -%}
func (m *{{ sheetname }}TableManager) GetRandomBy{{ col.name | title }}(key {{ to_go_type(col.data_type) }}) (*pb.{{ sheetname }}Table, bool) {
    rows := m.kv{{ col.name | title }}Data[key]
    if len(rows) == 0 {
        return nil, false
    }
    return rows[rand.IntN(len(rows))], true
}

{% endfor %}

// ---- Filter / FindFirst ----

func (m *{{ sheetname }}TableManager) Filter(pred func(*pb.{{ sheetname }}Table) bool) []*pb.{{ sheetname }}Table {
    var result []*pb.{{ sheetname }}Table
    for _, row := range m.data {
        if pred(row) {
            result = append(result, row)
        }
    }
    return result
}

func (m *{{ sheetname }}TableManager) FindFirst(pred func(*pb.{{ sheetname }}Table) bool) (*pb.{{ sheetname }}Table, bool) {
    for _, row := range m.data {
        if pred(row) {
            return row, true
        }
    }
    return nil, false
}

