{# proto_table.proto.j2 — generates one .proto file per data table #}
syntax = "proto3";

option go_package = "generated/pb/table";
{% if java_package %}
option java_package = "{{ java_package }}";
option java_outer_classname = "{{ table.name }}TableOuterClass";
option java_multiple_files = true;
{% endif %}

{% for group in table.groups.values() -%}
message {{ table.name }}{{ group.name }} {
{%- for col in group.columns %}
	{{ col.data_type }} {{ col.name }} = {{ loop.index }};
{%- endfor %}
}

{% endfor -%}
message {{ table.name }}Table {
{%- set ns = namespace(idx=1) -%}
{%- set seen = {} -%}
{%- for col in table.server_columns -%}
{%- if col.name not in seen -%}
{%- if col.map_role == "set" %}
	map <{{ col.data_type }}, bool> {{ col.name }} = {{ ns.idx }};
{%- set ns.idx = ns.idx + 1 -%}
{%- elif col.map_role in ("map_key", "map_value") -%}
{%- elif col.name in table.arrays %}
	repeated {{ col.data_type }} {{ col.name }} = {{ ns.idx }};
{%- set ns.idx = ns.idx + 1 -%}
{%- elif col.excel_index not in table.col_to_group %}
	{{ col.data_type }} {{ col.name }} = {{ ns.idx }};
{%- set ns.idx = ns.idx + 1 -%}
{%- endif -%}
{%- if seen.update({col.name: true}) %}{% endif -%}
{%- endif -%}
{%- endfor -%}
{%- for m in table.maps.values() %}
	map <{{ m.key_type }}, {{ m.value_type }}> {{ m.name }} = {{ ns.idx }};
{%- set ns.idx = ns.idx + 1 -%}
{%- endfor -%}
{%- for g in table.groups.values() %}
	repeated {{ table.name }}{{ g.name }} {{ g.name }} = {{ ns.idx }};
{%- set ns.idx = ns.idx + 1 -%}
{%- endfor %}
}

message {{ table.name }}TableData {
	repeated {{ table.name }}Table data = 1;
}
