class {{ sheetname }}TableManager {
public:
    using IdMapType = std::unordered_map<uint32_t, const {{ sheetname }}Table*>;
    using LoadSuccessCallback = std::function<void()>;

    // Internal snapshot holding all parsed data and indices.
    // Load() builds a new snapshot and swaps it in, replacing the old one.
    struct Snapshot {
        {{ sheetname }}TableData data;
        IdMapType idMap;
{%- for col in table.table_keys %}
        std::{{ cpp_map_type(col.is_multi_key) }}<{{ to_cpp_type(col.data_type) }}, const {{ sheetname }}Table*> {{ to_camel_case(col.name) }}Map;
{%- endfor %}
{%- for col in table.expression_columns %}
        ExcelExpression<{{ col.expression_type }}> {{ to_camel_case(col.name) }}Expr;
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
        std::unordered_multimap<{{ to_cpp_type(arr.data_type) }}, const {{ sheetname }}Table*> {{ to_camel_case(arr.name) }}Index;
{%- endfor %}
{%- for ck in table.composite_keys %}
        std::unordered_map<{{ sheetname }}{{ composite_cpp_struct_name(ck.group) }}, const {{ sheetname }}Table*, {{ sheetname }}{{ composite_cpp_struct_name(ck.group) }}Hash> {{ to_camel_case(ck.group) }}Composite;
{%- endfor %}
    };

    static {{ sheetname }}TableManager& Instance() {
        static {{ sheetname }}TableManager instance;
        return instance;
    }

    const Snapshot& GetSnapshot() const { return *snapshot; }

    const {{ sheetname }}TableData& FindAll() const { return snapshot->data; }

    std::pair<const {{ sheetname }}Table*, uint32_t> FindById(uint32_t tableId);
    std::pair<const {{ sheetname }}Table*, uint32_t> FindByIdSilent(uint32_t tableId);
    const IdMapType& GetIdMap() const { return snapshot->idMap; }

    void Load();

    void SetLoadSuccessCallback(const LoadSuccessCallback& callback) {
        loadSuccessCallback = callback;
    }

    void LoadSuccess() { if (loadSuccessCallback) { loadSuccessCallback(); } }

{% for col in table.table_keys %}
    std::pair<const {{ sheetname }}Table*, uint32_t> FindBy{{ to_pascal_case(col.name) }}({{ to_cpp_param_type(col.data_type) }} key) const;
    const std::{{ cpp_map_type(col.is_multi_key) }}<{{ to_cpp_type(col.data_type) }}, const {{ sheetname }}Table*>& Get{{ to_pascal_case(col.name) }}Map() const { return snapshot->{{ to_camel_case(col.name) }}Map; }
{% endfor %}

{% for col in table.expression_columns %}
    {{ col.expression_type }} Get{{ to_pascal_case(col.name) }}(uint32_t tableId) {
        auto [table, fetchResult] = FindById(tableId);
        if (table == nullptr) {
            return {{ col.expression_type }}();
        }
        return snapshot->{{ to_camel_case(col.name) }}Expr.Value(table->{{ col.name }}());
    }
    void Set{{ to_pascal_case(col.name) }}Param(const std::vector<{{ col.expression_type }}>& paramList) {
        snapshot->{{ to_camel_case(col.name) }}Expr.SetParam(paramList);
    }
{% endfor %}

{%- for col in table.foreign_key_columns %}
    // FK: {{ col.name }} -> {{ col.foreign_key.target_table }}.{{ col.foreign_key.target_column }}
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
    const std::unordered_multimap<{{ to_cpp_type(arr.data_type) }}, const {{ sheetname }}Table*>& Get{{ to_pascal_case(arr.name) }}Index() const { return snapshot->{{ to_camel_case(arr.name) }}Index; }
{%- endfor %}

    // ---- Exists ----

    bool Exists(uint32_t id) const { return snapshot->idMap.count(id) > 0; }

{%- for col in table.table_keys if not col.is_multi_key %}
    bool ExistsBy{{ to_pascal_case(col.name) }}({{ to_cpp_param_type(col.data_type) }} key) const { return snapshot->{{ to_camel_case(col.name) }}Map.count(key) > 0; }
{%- endfor %}

    // ---- Count ----

    std::size_t Count() const { return snapshot->idMap.size(); }

{%- for col in table.table_keys if col.is_multi_key %}
    std::size_t CountBy{{ to_pascal_case(col.name) }}({{ to_cpp_param_type(col.data_type) }} key) const { return snapshot->{{ to_camel_case(col.name) }}Map.count(key); }
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
    std::size_t CountBy{{ to_pascal_case(arr.name) }}Index({{ to_cpp_param_type(arr.data_type) }} key) const { return snapshot->{{ to_camel_case(arr.name) }}Index.count(key); }
{%- endfor %}

    // ---- FindByIds (IN) ----

    std::vector<const {{ sheetname }}Table*> FindByIds(const std::vector<uint32_t>& ids) const {
        std::vector<const {{ sheetname }}Table*> result;
        result.reserve(ids.size());
        for (auto id : ids) {
            if (auto it = snapshot->idMap.find(id); it != snapshot->idMap.end()) {
                result.push_back(it->second);
            }
        }
        return result;
    }

    // ---- RandOne ----

    const {{ sheetname }}Table* RandOne() const {
        if (snapshot->data.data_size() == 0) return nullptr;
        thread_local std::mt19937 rng{std::random_device{}()};
        std::uniform_int_distribution<int> dist(0, snapshot->data.data_size() - 1);
        return &snapshot->data.data(dist(rng));
    }

    // ---- Where / First ----

    std::vector<const {{ sheetname }}Table*> Where(const std::function<bool(const {{ sheetname }}Table&)>& pred) const {
        std::vector<const {{ sheetname }}Table*> result;
        for (int i = 0; i < snapshot->data.data_size(); ++i) {
            if (pred(snapshot->data.data(i))) {
                result.push_back(&snapshot->data.data(i));
            }
        }
        return result;
    }

    const {{ sheetname }}Table* First(const std::function<bool(const {{ sheetname }}Table&)>& pred) const {
        for (int i = 0; i < snapshot->data.data_size(); ++i) {
            if (pred(snapshot->data.data(i))) {
                return &snapshot->data.data(i);
            }
        }
        return nullptr;
    }

    // ---- Composite Key ----
{% for ck in table.composite_keys %}
    const {{ sheetname }}Table* FindBy{{ to_pascal_case(ck.group) }}({% for col in ck.columns %}{{ to_cpp_param_type(col.data_type) }} {{ col.name }}{% if not loop.last %}, {% endif %}{% endfor %}) const {
        auto it = snapshot->{{ to_camel_case(ck.group) }}Composite.find({ {%- for col in ck.columns %}{{ col.name }}{% if not loop.last %}, {% endif %}{% endfor -%} });
        return it != snapshot->{{ to_camel_case(ck.group) }}Composite.end() ? it->second : nullptr;
    }

    bool ExistsBy{{ to_pascal_case(ck.group) }}({% for col in ck.columns %}{{ to_cpp_param_type(col.data_type) }} {{ col.name }}{% if not loop.last %}, {% endif %}{% endfor %}) const {
        return snapshot->{{ to_camel_case(ck.group) }}Composite.count({ {%- for col in ck.columns %}{{ col.name }}{% if not loop.last %}, {% endif %}{% endfor -%} }) > 0;
    }
{% endfor %}

private:
    LoadSuccessCallback loadSuccessCallback;
    std::unique_ptr<Snapshot> snapshot = std::make_unique<Snapshot>();
};

