class {{ sheetname }}TableManager {
public:
    using KeyValueDataType = std::unordered_map<uint32_t, const {{ sheetname }}Table*>;
    using LoadSuccessCallback = std::function<void()>;

    static {{ sheetname }}TableManager& Instance() {
        static {{ sheetname }}TableManager instance;
        return instance;
    }

    const {{ sheetname }}TableData& FindAll() const { return data_; }

    std::pair<const {{ sheetname }}Table*, uint32_t> FindById(uint32_t tableId);
    std::pair<const {{ sheetname }}Table*, uint32_t> FindByIdSilent(uint32_t tableId);
    const KeyValueDataType& KeyValueData() const { return kv_data_; }

    void Load();

    void SetLoadSuccessCallback(const LoadSuccessCallback& callback) {
        loadSuccessCallback_ = callback;
    }

    void LoadSuccess() { if (loadSuccessCallback_) { loadSuccessCallback_(); } }

{% for col in table.table_keys %}
    std::pair<const {{ sheetname }}Table*, uint32_t> FindBy{{ col.name | title }}({{ to_cpp_param_type(col.data_type) }} tableId) const;
    const std::{{ cpp_map_type(col.is_multi_key) }}<{{ to_cpp_type(col.data_type) }}, const {{ sheetname }}Table*>& Get{{ col.name | title }}Data() const { return kv_{{ col.name }}data_; }
{% endfor %}

{% for col in table.expression_columns %}
    {{ col.expression_type }} Get{{ col.name | title }}(uint32_t tableId) {
        auto [table, ok] = FindById(tableId);
        if (!ok || table == nullptr) {
            LOG_ERROR << "{{ col.name | title }} table not found for ID: " << tableId;
            return {{ col.expression_type }}();
        }
        return expression_{{ col.name }}_.Value(table->{{ col.name }}());
    }
    void Set{{ col.name | title }}Param(const std::vector<{{ col.expression_type }}>& paramList) {
        expression_{{ col.name }}_.SetParam(paramList);
    }
{% endfor %}

{%- for col in table.foreign_key_columns %}
    // FK: {{ col.name }} → {{ col.foreign_key.target_table }}.{{ col.foreign_key.target_column }}
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
    const std::unordered_multimap<{{ to_cpp_type(arr.data_type) }}, const {{ sheetname }}Table*>& Get{{ arr.name | title }}Index() const { return idx_{{ arr.name }}_; }
{%- endfor %}

    // ---- Exists ----

    bool Exists(uint32_t id) const { return kv_data_.count(id) > 0; }

{%- for col in table.table_keys if not col.is_multi_key %}
    bool ExistsBy{{ col.name | title }}({{ to_cpp_param_type(col.data_type) }} key) const { return kv_{{ col.name }}data_.count(key) > 0; }
{%- endfor %}

    // ---- Count ----

    std::size_t Count() const { return kv_data_.size(); }

{%- for col in table.table_keys if col.is_multi_key %}
    std::size_t CountBy{{ col.name | title }}({{ to_cpp_param_type(col.data_type) }} key) const { return kv_{{ col.name }}data_.count(key); }
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
    std::size_t CountBy{{ arr.name | title }}Index({{ to_cpp_param_type(arr.data_type) }} key) const { return idx_{{ arr.name }}_.count(key); }
{%- endfor %}

    // ---- FindByIds (IN) ----

    std::vector<const {{ sheetname }}Table*> FindByIds(const std::vector<uint32_t>& ids) const {
        std::vector<const {{ sheetname }}Table*> result;
        result.reserve(ids.size());
        for (auto id : ids) {
            if (auto it = kv_data_.find(id); it != kv_data_.end()) {
                result.push_back(it->second);
            }
        }
        return result;
    }

    // ---- RandOne ----

    const {{ sheetname }}Table* RandOne() const {
        if (data_.data_size() == 0) return nullptr;
        thread_local std::mt19937 rng{std::random_device{}()};
        std::uniform_int_distribution<int> dist(0, data_.data_size() - 1);
        return &data_.data(dist(rng));
    }

    // ---- Where / First ----

    std::vector<const {{ sheetname }}Table*> Where(const std::function<bool(const {{ sheetname }}Table&)>& pred) const {
        std::vector<const {{ sheetname }}Table*> result;
        for (int i = 0; i < data_.data_size(); ++i) {
            if (pred(data_.data(i))) {
                result.push_back(&data_.data(i));
            }
        }
        return result;
    }

    const {{ sheetname }}Table* First(const std::function<bool(const {{ sheetname }}Table&)>& pred) const {
        for (int i = 0; i < data_.data_size(); ++i) {
            if (pred(data_.data(i))) {
                return &data_.data(i);
            }
        }
        return nullptr;
    }

    // ---- Composite Key ----
{% for ck in table.composite_keys %}
    const {{ sheetname }}Table* FindBy{{ ck.group | title }}({% for col in ck.columns %}{{ to_cpp_param_type(col.data_type) }} {{ col.name }}{% if not loop.last %}, {% endif %}{% endfor %}) const {
        auto it = composite_kv_{{ ck.group }}_.find({ {%- for col in ck.columns %}{{ col.name }}{% if not loop.last %}, {% endif %}{% endfor -%} });
        return it != composite_kv_{{ ck.group }}_.end() ? it->second : nullptr;
    }

    bool ExistsBy{{ ck.group | title }}({% for col in ck.columns %}{{ to_cpp_param_type(col.data_type) }} {{ col.name }}{% if not loop.last %}, {% endif %}{% endfor %}) const {
        return composite_kv_{{ ck.group }}_.count({ {%- for col in ck.columns %}{{ col.name }}{% if not loop.last %}, {% endif %}{% endfor -%} }) > 0;
    }
{% endfor %}

private:
    LoadSuccessCallback loadSuccessCallback_;
    {{ sheetname }}TableData data_;
    KeyValueDataType kv_data_;
{%- for col in table.table_keys %}
    std::{{ cpp_map_type(col.is_multi_key) }}<{{ to_cpp_type(col.data_type) }}, const {{ sheetname }}Table*> kv_{{ col.name }}data_;
{%- endfor %}
{%- for col in table.expression_columns %}
    ExcelExpression<{{ col.expression_type }}> expression_{{ col.name }}_;
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
    std::unordered_multimap<{{ to_cpp_type(arr.data_type) }}, const {{ sheetname }}Table*> idx_{{ arr.name }}_;
{%- endfor %}
{%- for ck in table.composite_keys %}
    std::unordered_map<{{ sheetname }}{{ composite_cpp_struct_name(ck.group) }}, const {{ sheetname }}Table*, {{ sheetname }}{{ composite_cpp_struct_name(ck.group) }}Hash> composite_kv_{{ ck.group }}_;
{%- endfor %}
};

inline const {{ sheetname }}TableData& FindAll{{ sheetname }}Table() {
