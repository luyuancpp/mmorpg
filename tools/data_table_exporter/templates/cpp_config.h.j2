struct {{ sheetname }}{{ composite_cpp_struct_name(ck.group) }}Hash {
    std::size_t operator()(const {{ sheetname }}{{ composite_cpp_struct_name(ck.group) }}& k) const {
        std::size_t seed = 0;
{%- for col in ck.columns %}
        seed ^= std::hash<{{ to_cpp_type(col.data_type) }}>{}(k.{{ col.name }}) + 0x9e3779b9 + (seed << 6) + (seed >> 2);
{%- endfor %}
        return seed;
    }
};
