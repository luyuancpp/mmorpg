{# cpp_config.cpp.j2 — per-table config manager implementation #}
#include "google/protobuf/util/json_util.h"
#include "core/utils/file/file2string.h"
#include "table/proto/tip/common_error_tip.pb.h"
#include "table/code/{{ sheetname | lower }}_table.h"

std::string GetConfigDir();
bool UseProtoBinaryTables();

void {{ sheetname }}TableManager::Load() {
    auto snap = std::make_unique<Snapshot>();

    if (UseProtoBinaryTables()) {
        const std::string path = GetConfigDir() + "{{ sheetname | lower }}.pb";
        const auto contents = File2String(path);
        if (!snap->data.ParseFromString(contents)) {
            LOG_FATAL << "{{ sheetname }} binary parse failed: " << path;
        }
    } else {
        const std::string path = GetConfigDir() + "{{ sheetname | lower }}.json";
        const auto contents = File2String(path);
        if (const auto result = google::protobuf::util::JsonStringToMessage(contents.data(), &snap->data); !result.ok()) {
            LOG_FATAL << "{{ sheetname }}" << result.message().data();
        }
    }

    for (int32_t i = 0; i < snap->data.data_size(); ++i) {
        const auto& row_data = snap->data.data(i);
        snap->kvData.emplace(row_data.id(), &row_data);
{%- for col in table.table_keys %}
        snap->kv{{ col.name }}.emplace(row_data.{{ col.name }}(), &row_data);
{%- endfor %}
{%- for arr in table.repeated_comp_arrays %}
        for (const auto& elem : row_data.{{ arr.name }}()) {
            snap->idx{{ arr.name }}.emplace(elem, &row_data);
        }
{%- endfor %}
{%- for ck in table.composite_keys %}
        snap->compositeKv{{ ck.group }}.emplace({{ sheetname }}{{ composite_cpp_struct_name(ck.group) }}{ {%- for col in ck.columns %}row_data.{{ col.name }}(){% if not loop.last %}, {% endif %}{% endfor -%} }, &row_data);
{%- endfor %}
    }
{%- for col in table.expression_columns if col.expression_params %}

    snap->expression{{ col.name }}.Init({
{%- for p in col.expression_params %}
        "{{ p }}"{% if not loop.last %}, {% endif %}
{%- endfor %}
    });
{%- endfor %}

    snapshot_ = std::move(snap);
}

std::pair<const {{ sheetname }}Table*, uint32_t> {{ sheetname }}TableManager::FindById(const uint32_t tableId) {
    const auto& snap = GetSnapshot();
    const auto it = snap.kvData.find(tableId);
    if (it == snap.kvData.end()) {
        LOG_ERROR << "{{ sheetname }} table not found for ID: " << tableId;
        return {nullptr, kInvalidTableId};
    }
    return {it->second, kSuccess};
}

std::pair<const {{ sheetname }}Table*, uint32_t> {{ sheetname }}TableManager::FindByIdSilent(const uint32_t tableId) {
    const auto& snap = GetSnapshot();
    const auto it = snap.kvData.find(tableId);
    if (it == snap.kvData.end()) {
        return {nullptr, kInvalidTableId};
    }
    return {it->second, kSuccess};
}

{% for col in table.table_keys -%}
std::pair<const {{ sheetname }}Table*, uint32_t> {{ sheetname }}TableManager::FindBy{{ col.name | title }}({{ to_cpp_param_type(col.data_type) }} key) const {
    const auto& snap = GetSnapshot();
    const auto it = snap.kv{{ col.name }}.find(key);
    if (it == snap.kv{{ col.name }}.end()) {
        LOG_ERROR << "{{ sheetname }} table not found for {{ col.name }}: " << key;
        return {nullptr, kInvalidTableId};
    }
    return {it->second, kSuccess};
}

{% endfor %}
