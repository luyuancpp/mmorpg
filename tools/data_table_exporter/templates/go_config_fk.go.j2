// Get{{ sheetname }}{{ to_go_proto_field(col.name) }}RowsById resolves {{ sheetname }}.{{ col.name }}[] -> {{ col.group_foreign_key.target_table }} rows (by {{ sheetname }} id).
func Get{{ sheetname }}{{ to_go_proto_field(col.name) }}RowsById(tableId uint32) []*pb.{{ col.group_foreign_key.target_table }}Table {
    row, ok := {{ sheetname }}TableManagerInstance.FindById(tableId)
