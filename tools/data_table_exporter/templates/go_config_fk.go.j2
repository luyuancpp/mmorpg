{# go_config_fk.go.j2 -- foreign key cross-table lookup helpers #}
package table

import (
    pb "{{ proto_import_path }}"
)

// ---------------------------------------------------------------------------
// Foreign key helpers for {{ sheetname }}Table
// ---------------------------------------------------------------------------
{% for col in table.foreign_key_columns %}
{% if col.is_repeated %}

// Get{{ sheetname }}{{ to_go_proto_field(col.name) }}Rows resolves {{ sheetname }}.{{ col.name }}[] -> {{ col.foreign_key.target_table }} rows.
func Get{{ sheetname }}{{ to_go_proto_field(col.name) }}Rows(row *pb.{{ sheetname }}Table) []*pb.{{ col.foreign_key.target_table }}Table {
    var result []*pb.{{ col.foreign_key.target_table }}Table
    for _, id := range row.{{ to_go_proto_field(col.name) }} {
        if r, ok := {{ col.foreign_key.target_table }}TableManagerInstance.FindById(id); ok {
            result = append(result, r)
        }
    }
    return result
}

// Get{{ sheetname }}{{ to_go_proto_field(col.name) }}RowsById resolves {{ sheetname }}.{{ col.name }}[] -> {{ col.foreign_key.target_table }} rows (by {{ sheetname }} id).
func Get{{ sheetname }}{{ to_go_proto_field(col.name) }}RowsById(tableId uint32) []*pb.{{ col.foreign_key.target_table }}Table {
    row, ok := {{ sheetname }}TableManagerInstance.FindById(tableId)
    if !ok {
        return nil
    }
    return Get{{ sheetname }}{{ to_go_proto_field(col.name) }}Rows(row)
}
{% else %}

// Get{{ sheetname }}{{ to_go_proto_field(col.name) }}Row resolves {{ sheetname }}.{{ col.name }} -> {{ col.foreign_key.target_table }} row.
func Get{{ sheetname }}{{ to_go_proto_field(col.name) }}Row(row *pb.{{ sheetname }}Table) (*pb.{{ col.foreign_key.target_table }}Table, bool) {
    return {{ col.foreign_key.target_table }}TableManagerInstance.FindById(row.{{ to_go_proto_field(col.name) }})
}

// Get{{ sheetname }}{{ to_go_proto_field(col.name) }}RowById resolves {{ sheetname }}.{{ col.name }} -> {{ col.foreign_key.target_table }} row (by {{ sheetname }} id).
func Get{{ sheetname }}{{ to_go_proto_field(col.name) }}RowById(tableId uint32) (*pb.{{ col.foreign_key.target_table }}Table, bool) {
    row, ok := {{ sheetname }}TableManagerInstance.FindById(tableId)
    if !ok {
        return nil, false
    }
    return Get{{ sheetname }}{{ to_go_proto_field(col.name) }}Row(row)
}
{% endif %}
{% endfor %}
