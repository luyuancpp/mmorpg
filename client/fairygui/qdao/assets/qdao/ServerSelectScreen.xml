<?xml version="1.0" encoding="utf-8"?>
<!--
  ServerSelectScreen — qdao package, design space 2560x1080.

  Layout invariants (DON'T break these without updating ServerSelectScreen.cs):
   - listTabs:   single column, 6 items, defaultItem=QdaoTabIdle (180x72).
                 Container 180 wide × (6*72 + 5*8) = 472 tall, exact fit so
                 no scroll pane is created and items can't drift.
   - listServer: 2 columns × 4 rows fixed grid (layout="pagination").
                 Each card 450x96. Container = 2*450 + 10 columnGap = 910,
                 rounded up to 940 for breathing room. Height = 4*96 + 3*12 = 396,
                 rounded up to 432.
                 ⚠ NEVER set layout="flow_vt" here — flow_vt auto-derives
                 column count from container width and gives 3-or-4 columns
                 depending on rounding. pagination locks the grid.
   - Bottom action bar at y≈779: btnBack | btnRefresh | btnConfirm.
-->
<component size="2560,1080">
  <displayList>
    <image id="n0" name="imgSceneBackdrop" src="0001003a" fileName="qdao_scene_bg.png" xy="0,0" size="2560,1080"/>
    <image id="nOV" name="imgUiOverlay"    src="0001003b" fileName="qdao_ui_overlay_bg.png" xy="-10,-10" size="2560,1080"/>

    <text id="n1" name="txtPanelTitle" xy="900,150" size="760,90"
          fontSize="64" color="#3d2914" align="center" vAlign="middle"
          autoSize="none" singleLine="true" text="选择区服"/>

    <component id="n2" name="searchBox" src="c0000003" fileName="common/QdaoSearchBox.xml"
               xy="1598,247" size="280,76"/>

    <!-- Left tab list — single-column, exact-fit container -->
    <list id="n3" name="listTabs" xy="756,346" size="180,472"
          selectionMode="Single" lineGap="8"
          defaultItem="ui://qdao/QdaoTabIdle" align="center">
      <item title="近期" icon="ui://qdao/icon_alt_left_tab_icon_1.png"/>
      <item title="推荐" icon="ui://qdao/icon_alt_left_tab_icon_2.png"/>
      <item title="全部" icon="ui://qdao/icon_alt_left_tab_icon_3.png"/>
      <item title="新服" icon="ui://qdao/icon_alt_left_tab_icon_4.png"/>
      <item title="官方" icon="ui://qdao/icon_category_yinyang.png"/>
      <item title="海外" icon="ui://qdao/icon_category_swirl.png"/>
    </list>

    <!-- Center server list — pagination 2×4 (see layout invariants above) -->
    <list id="n4" name="listServer" xy="995,346" size="940,432"
          layout="pagination" selectionMode="Single" overflow="scroll"
          lineGap="12" columnGap="10"
          defaultItem="ui://qdao/QdaoServerCard" align="center">
      <item title="云海宗" icon="ui://qdao/icon_server_badge_pavilion.png"/>
      <item title="清风谷" icon="ui://qdao/icon_server_badge_pagoda.png"/>
      <item title="碧落渊" icon="ui://qdao/icon_server_badge_sword.png"/>
      <item title="紫霄峰" icon="ui://qdao/icon_server_badge_whirlpool.png"/>
      <item title="沧浪洲" icon="ui://qdao/icon_server_badge_yinyang.png"/>
      <item title="昆仑墟" icon="ui://qdao/icon_server_badge_mountain.png"/>
      <item title="蓬莱岛" icon="ui://qdao/icon_server_badge_lotus.png"/>
      <item title="瀛洲海" icon="ui://qdao/icon_server_badge_talisman.png"/>
      <item title="九霄殿" icon="ui://qdao/icon_server_badge_pavilion.png"/>
      <item title="太虚观" icon="ui://qdao/icon_server_badge_pagoda.png"/>
      <item title="玄都阁" icon="ui://qdao/icon_server_badge_sword.png"/>
      <item title="赤霞岭" icon="ui://qdao/icon_server_badge_whirlpool.png"/>
    </list>

    <!-- Bottom action bar — back, refresh, confirm.
         btnConfirm is the ONLY way to enter a server now (the per-card
         进入/详情 buttons were removed in QdaoServerCard.xml). -->
    <component id="n7" name="btnBack" src="c0000002" fileName="common/QdaoButtonSecondary.xml"
               xy="1100,779" size="300,84">
      <Button title="返回" titleFontSize="26"/>
    </component>
    <component id="n8" name="btnRefresh" src="c0000002" fileName="common/QdaoButtonSecondary.xml"
               xy="1520,780" size="300,84">
      <Button title="刷新" titleFontSize="26"/>
    </component>
    <component id="n9" name="btnConfirm" src="c0000001" fileName="common/QdaoButtonPrimary.xml"
               xy="1940,775" size="320,92">
      <Button title="进入" titleFontSize="32"/>
    </component>

    <!-- Status line just below the action bar — used for "请选择服务器" /
         "正在连接…" feedback. Empty by default; ServerSelectScreen.cs sets it. -->
    <text id="n10" name="txtStatus" xy="900,890" size="760,32"
          fontSize="22" color="#fff0bd" align="center" vAlign="middle"
          autoSize="none" singleLine="true" text=""/>
  </displayList>
</component>
