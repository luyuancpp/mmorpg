<?xml version="1.0" encoding="utf-8"?>
<!--
  QdaoServerCard — 2-column grid card (450x96).

  Layout:  [badge 80x80] [statusIcon] [title] [subtitle]
  No inline 进入/详情 buttons — selection drives the bottom-bar btnConfirm
  in ServerSelectScreen. The whole card is the hit area.

  Used by ServerSelectScreen.listServer with layout="pagination" so the
  grid stays 2 columns regardless of small container-size drift. Sizing
  here MUST stay consistent with the listServer container math:

      container 940 wide  = 2 * 450 + 10 (columnGap) + 30 (slack)
      container 432 tall  = 4 *  96 + 3 * 12 (lineGap) + 0  (slack)

  ⚠ Don't widen this card past 460 without bumping the container too —
  pagination will silently drop to 1 column if 2 cards no longer fit.
-->
<component size="450,96" extention="Button" opaque="false">
  <controller name="button"  pages="up,,down,,over,,disabled," selected="0"/>
  <controller name="checked" pages="0,,1," selected="0"/>
  <controller name="status"  pages="0,,1,,2," selected="0"/>

  <displayList>
    <!-- Card background + foreground (foreground tints amber on selection) -->
    <image id="n0" name="bg" src="00010005" fileName="server_card_640x128_bg.png" xy="0,0" size="450,96">
      <relation target="" sidePair="width-width,height-height"/>
    </image>
    <image id="n1" name="fg" src="0001000d" fileName="server_card_640x128_fg.png" xy="0,0" size="450,96">
      <relation target="" sidePair="width-width,height-height"/>
      <gearColor controller="checked" values="#ffffff,#fff0bd"/>
    </image>

    <!-- Server emblem on the left -->
    <loader id="n2" name="badge" xy="10,8" size="80,80"
            url="ui://qdao202600010031" fill="scale" align="center" vAlign="middle"/>

    <!-- Status traffic-light dot (green / red), hidden on status=2 (unknown) -->
    <loader id="n3" name="statusIcon" xy="100,10" size="22,22"
            url="ui://qdao202600010024" fill="scale" align="center" vAlign="middle">
      <gearDisplay controller="status" pages="0,1"/>
    </loader>

    <!-- Title — turns red when the card is checked (selected) -->
    <text id="n4" name="title" xy="130,8" size="310,32"
          fontSize="24" color="#3d2914" autoSize="none" singleLine="true" text="server name">
      <gearColor controller="checked" values="#3d2914,#9c2b1a"/>
    </text>

    <!-- Subtitle: "畅通  人气旺" / "拥挤" / "维护中" set by code -->
    <text id="n5" name="subtitle" xy="130,42" size="310,24"
          fontSize="18" color="#5a4025" autoSize="none" singleLine="true" text="畅通  人气旺"/>

    <!-- Hit area covers the whole card; the component itself is a Button so
         FairyGUI auto-routes clicks through this graph. -->
    <graph id="n8" name="hit" xy="0,0" size="450,96"
           type="rect" lineSize="0" lineColor="#00000000" fillColor="#00000000"/>
  </displayList>

  <Button mode="Check" downEffect="scale" downEffectValue="0.98"/>
</component>
