# FairyGUI atlas/asset rework backups (kept locally as safety net,
# never committed). Restoring is just a file copy from these dirs.
client/fairygui/qdao/assets/_backup_*/

# Scratch screenshots / debug captures under image/.
# The "effect" art (q_daoist_*.png design plates, ui_controls_v2/, the
# *_notes.md design notes) is tracked and stays in version control —
# these rules only catch the throwaway stuff: preview renders from
# preview_qdao_screens.py, "_shot_latest" / "_error_latest" snapshots,
# before/after diff PNGs, and any pasted-from-clipboard JPEGs (the
# project's real plates are all PNG, so blocking *.jpg is safe).
image/_*.png
image/error*.png
image/*.jpg
image/*.jpeg

# Atomic-layer intermediate plates from the AI redraw pipeline. These are
# regeneratable from the *_redraw_*.py scripts and amount to hundreds of MB
# per redraw run; the FINAL composed PNGs (top-level of each redraw_layers/
# directory) are the only files worth committing. Keeps git history slim.
q_daoist_login_buttons_redrawn_atomic/

# Per-machine artefacts that should never be committed.
#
# - bin/.claude/ : Claude Code's per-checkout settings.local.json (the
#   command-allowlist is personal, not team state — sharing it would
#   silently grant every teammate the union of everyone's "Allow" clicks).
# - bin/go_services/, bin/cpp_services/ : compiled service binaries,
#   regenerated by the build pipeline.
# - robot/.../ : leftover from a broken path expansion; not a real dir.
# - *.exe.old, *.exe~ : rotated binaries kept locally for rollback.
# - tools/proto/protogen/ : prebuilt protoc plugins and grpc codegen
#   binaries — checked-out per platform, not source.
bin/.claude/
bin/go_services/
bin/cpp_services/
robot/.../
*.exe.old
*.exe~
tools/proto/protogen/
